@startuml
title C5 分层图
!include _theme.iuml

rectangle "主启动入口\nupstream/esp_hosted_coprocessor.c" as Entry
rectangle "项目定制边界\ncoprocessor_entry / feature_flags / Kconfig" as Product
rectangle "控制与能力层\nupstream/slave_control / slave_wifi_std" as Control
rectangle "传输层\nupstream/sdio_slave_api 等" as Transport
