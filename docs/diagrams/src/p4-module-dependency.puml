@startuml
title P4 模块依赖图
!include _theme.iuml

package "P4 Firmware" {
  [main.c] as Main
  [app_boot.c] as Boot
  [wifi_app] as Wifi
  [console_app] as Console
  [network/command/*] as NetCmd
  [bridge_cmd] as BridgeCmd
  [network/service/*] as NetApp
  [bridge/service/*] as Bridge
  [uart_port.cpp] as Uart
}

Main --> Boot
Boot --> Wifi
Boot --> Bridge
Boot --> Console
Console --> NetCmd
Console --> BridgeCmd
NetCmd --> NetApp
BridgeCmd --> Bridge
Bridge --> Wifi
Bridge --> Uart
@enduml
